#!/usr/bin/env bash
# ============================================================================
# recon-pipeline installer for Kali Linux
# Offizielle Quellen:
# subfinder      https://github.com/projectdiscovery/subfinder
# httpx          https://github.com/projectdiscovery/httpx
# gau            https://github.com/lc/gau
# waybackurls    https://github.com/tomnomnom/waybackurls
# LinkFinder     https://github.com/GerbenJavado/LinkFinder
# ParamSpider    https://github.com/devanshbatham/ParamSpider
# Arjun          https://github.com/s0md3v/Arjun
# Gobuster       https://github.com/OJ/gobuster
# Kiterunner     https://github.com/assetnote/kiterunner
# XSStrike       https://github.com/s0md3v/XSStrike
# sqlmap         https://github.com/sqlmapproject/sqlmap
# ============================================================================
set -euo pipefail

# ----------------------------------------------------------------------------
# Konfiguration
# ----------------------------------------------------------------------------
TOOLS_DIR="${TOOLS_DIR:-$HOME/tools}"

mkdir -p "$TOOLS_DIR"

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
log()  { printf "\033[1;36m[*]\033[0m %s\n" "$*"; }
ok()   { printf "\033[1;32m[+]\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m[!]\033[0m %s\n" "$*"; }
err()  { printf "\033[1;31m[-]\033[0m %s\n" "$*" >&2; }

# ----------------------------------------------------------------------------
# System Dependencies
# ----------------------------------------------------------------------------
log "Installiere Basis-Dependencies..."
sudo apt-get update -qq
sudo apt-get install -y -qq \
    golang-go git python3 python3-pip curl wget unzip \
    libpcap-dev build-essential

if command -v go >/dev/null 2>&1; then
    GO_BIN="$(go env GOPATH)/bin"
else
    GO_BIN="$HOME/go/bin"
fi

# PATH erweitern
export PATH="$GO_BIN:$TOOLS_DIR:$PATH"

if ! grep -Fq "$GO_BIN" "$HOME/.bashrc" 2>/dev/null; then
    printf 'export PATH="$PATH:%s"\n' "$GO_BIN" >> "$HOME/.bashrc"
fi

if ! grep -Fq "$TOOLS_DIR" "$HOME/.bashrc" 2>/dev/null; then
    printf 'export PATH="$PATH:%s"\n' "$TOOLS_DIR" >> "$HOME/.bashrc"
fi

# ----------------------------------------------------------------------------
# Go Tools
# ----------------------------------------------------------------------------
log "Installiere Go-Tools..."

go install -v github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest && ok "subfinder"
go install -v github.com/projectdiscovery/httpx/cmd/httpx@latest             && ok "httpx"
go install -v github.com/lc/gau/v2/cmd/gau@latest                            && ok "gau"
go install -v github.com/tomnomnom/waybackurls@latest                        && ok "waybackurls"
go install -v github.com/OJ/gobuster/v3@latest                                && ok "gobuster"

# ----------------------------------------------------------------------------
# Python Tools
# ----------------------------------------------------------------------------
log "Installiere Python-Tools..."

python3 -m pip install --quiet --break-system-packages arjun \
    || python3 -m pip install --quiet --user arjun

ok "arjun"

# ----------------------------------------------------------------------------
# Git Repositories
# ----------------------------------------------------------------------------
log "Clone GitHub Tools..."

clone_repo() {
    local url="$1"
    local dest="$2"

    if [[ -d "$dest" ]]; then
        warn "$dest existiert bereits – übersprungen"
        return 0
    fi

    git clone --depth 1 "$url" "$dest"
}

clone_repo "https://github.com/GerbenJavado/LinkFinder.git" "$TOOLS_DIR/LinkFinder"
( cd "$TOOLS_DIR/LinkFinder" && \
  python3 -m pip install --quiet --break-system-packages -r requirements.txt || \
  python3 -m pip install --quiet --user -r requirements.txt )
ok "LinkFinder"

clone_repo "https://github.com/devanshbatham/ParamSpider.git" "$TOOLS_DIR/ParamSpider"
ok "ParamSpider"

clone_repo "https://github.com/s0md3v/XSStrike.git" "$TOOLS_DIR/XSStrike"
( cd "$TOOLS_DIR/XSStrike" && \
  python3 -m pip install --quiet --break-system-packages -r requirements.txt || \
  python3 -m pip install --quiet --user -r requirements.txt )
ok "XSStrike"

clone_repo "https://github.com/sqlmapproject/sqlmap.git" "$TOOLS_DIR/sqlmap"
ok "sqlmap"

# ----------------------------------------------------------------------------
# Kiterunner
# ----------------------------------------------------------------------------
log "Installiere Kiterunner..."

KR_VERSION="1.0.0"
KR_TARBALL="kiterunner-${KR_VERSION}-linux-amd64.tar.gz"
KR_URL="https://github.com/assetnote/kiterunner/releases/download/v${KR_VERSION}/${KR_TARBALL}"

if ! command -v kr >/dev/null 2>&1; then
    KR_TMP="$(mktemp -d)"
    trap 'rm -rf "$KR_TMP"' EXIT
    cd "$KR_TMP"
    wget -q "$KR_URL" -O "$KR_TARBALL" || curl -fsSL "$KR_URL" -o "$KR_TARBALL"

    tar -xzf "$KR_TARBALL"

    KR_BIN="$(find . -maxdepth 2 -type f \( -name kr -o -name kiterunner \) -perm /111 | head -n 1)"
    if [[ -z "$KR_BIN" ]]; then
        err "Kiterunner-Binary nicht im Release-Archiv gefunden"
        exit 1
    fi

    sudo install -m 0755 "$KR_BIN" /usr/local/bin/kr 2>/dev/null || \
        install -m 0755 "$KR_BIN" "$TOOLS_DIR/kr"

    mkdir -p "$TOOLS_DIR/kiterunner-wordlists"

    wget -q \
      "https://github.com/assetnote/kiterunner/raw/master/kite/200000-endpoints.kite" \
      -O "$TOOLS_DIR/kiterunner-wordlists/large.kite" || true

    ok "kiterunner"
else
    warn "kiterunner bereits installiert"
fi

# ----------------------------------------------------------------------------
# Wordlists
# ----------------------------------------------------------------------------
log "Installiere Wordlists..."

WORDLIST_DIR="$HOME/wordlists"
mkdir -p "$WORDLIST_DIR"

if [[ ! -f "$WORDLIST_DIR/directory-list-2.3-medium.txt" ]]; then
    wget -q \
      "https://raw.githubusercontent.com/danielmiessler/SecLists/master/Discovery/Web-Content/directory-list-2.3-medium.txt" \
      -O "$WORDLIST_DIR/directory-list-2.3-medium.txt" || \
      warn "Wordlist Download fehlgeschlagen"
fi

# ----------------------------------------------------------------------------
# Abschluss
# ----------------------------------------------------------------------------
cat <<EOF

==============================================================================
Installation abgeschlossen
==============================================================================

Go Tools:      $GO_BIN
Git Tools:     $TOOLS_DIR
Wordlists:     $WORDLIST_DIR

Ausführen:
  ./recon.py -d example.com

Danach:
  source ~/.bashrc

==============================================================================
EOF
